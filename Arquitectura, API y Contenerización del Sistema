\section{Contratos de Interfaz (OpenAPI 3.0)}

Los contratos completos se encuentran exportados en formato YAML dentro de la carpeta \texttt{/docs/api/} del repositorio. A continuación se presenta el contrato correspondiente a \texttt{auth-service}, que debe contemplar los tres flujos exigidos: registro, autenticación y validación de token.

\begin{lstlisting}[caption={Contrato OpenAPI 3.0 de auth-service (docs/api/auth.yaml)}, label={lst:openapi-auth}]
openapi: 3.0.3
info:
  title: auth-service
  version: "1.0.0"
paths:
  /auth/register:
    post:
      summary: Registra un nuevo usuario con un rol asignado
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              required: [username, password, role]
              properties:
                username: { type: string }
                password: { type: string, format: password }
                role:
                  type: string
                  enum: [cliente, tecnico, administrador, superusuario]
      responses:
        "201": { description: Usuario registrado }
        "409": { description: El usuario ya existe }
  /auth/login:
    post:
      summary: Autentica al usuario y devuelve un JWT con su rol
      responses:
        "200": { description: Login correcto, JWT en data.access_token }
        "401": { description: Credenciales invalidas }
  /auth/validate:
    get:
      summary: Verifica la validez de un token Bearer
      security: [ { bearerAuth: [] } ]
      responses:
        "200": { description: Token valido }
        "401": { description: Token invalido o expirado }
components:
  securitySchemes:
    bearerAuth: { type: http, scheme: bearer, bearerFormat: JWT }
\end{lstlisting}

\begin{lstlisting}[caption={Contrato OpenAPI 3.0 de resource-service (docs/api/resource.yaml)}, label={lst:openapi-resource}]
openapi: 3.0.3
info:
  title: resource-service
  version: "1.0.0"
paths:
  /resources:
    get:
      summary: Lista los tickets de soporte tecnico
      security: [ { bearerAuth: [] } ]
      responses:
        "200": { description: Listado recuperado }
        "401": { description: Token requerido }
    post:
      summary: Crea un nuevo ticket de soporte
      security: [ { bearerAuth: [] } ]
      responses:
        "201": { description: Ticket creado }
  /resources/{id}:
    put:
      summary: Actualiza el estado o asignacion de un ticket
      security: [ { bearerAuth: [] } ]
      responses:
        "200": { description: Ticket actualizado }
    delete:
      summary: Elimina un ticket
      security: [ { bearerAuth: [] } ]
      responses:
        "200": { description: Ticket eliminado }
components:
  securitySchemes:
    bearerAuth: { type: http, scheme: bearer, bearerFormat: JWT }
\end{lstlisting}
